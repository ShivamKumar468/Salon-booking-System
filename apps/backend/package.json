{
  "name": "@salon/backend",
  "version": "1.0.0",
  "description": "Express backend for AI-powered salon booking system",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "npm run build --workspace=@salon/shared && prisma generate --schema=../../packages/shared/prisma/schema.prisma && tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate --schema=../../packages/shared/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=../../packages/shared/prisma/schema.prisma",
    "postinstall": "npm run build --workspace=@salon/shared && prisma generate --schema=../../packages/shared/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "@salon/shared": "*",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "rate-limiter-flexible": "^5.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.24",
    "prisma": "^5.10.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
